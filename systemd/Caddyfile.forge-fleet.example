# Example Caddy config for Forge Fleet (HTTP, all interfaces).
# install-caddy-fleet.sh writes the real file with the bearer token inlined (no {$ENV}),
# so older Ubuntu `caddy` builds work without `caddy run --environ`.
#
# Upstream: Fleet on 127.0.0.1:18765 (loopback-only; see docs/CADDY-SYSTEMD.md).

{
	admin off
}

:18766 {
	encode gzip
	reverse_proxy 127.0.0.1:18765 {
		header_up Authorization "Bearer REPLACE_AT_INSTALL_TIME"
	}
}

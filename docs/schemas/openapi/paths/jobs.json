  "/v1/jobs": {
    "post": {
      "tags": [
        "v1"
      ],
      "summary": "Create docker_argv job",
      "security": [
        {
          "bearerAuth": []
        }
      ],
      "responses": {
        "200": {
          "description": "See forge-fleet docs for response body; JSON object."
        },
        "401": {
          "description": "See forge-fleet docs for response body; JSON object.",
          "content": {

        "201": {
          "description": "Job accepted and queued (or awaiting workspace upload).",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/JobAcceptedResponse"
              }
            }
          }
        }
      },
      "operationId": "createJob",
      "requestBody": {

            "schema": {
              "$ref": "#/components/schemas/JobCreateRequest"
            }
          }
        }
      },
      "description": "Create docker_argv job. Operator narrative, authentication, and curl patterns: `docs/reference/01-http-api-reference.md`."
    }
  },

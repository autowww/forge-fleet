{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fleet.forgesdlc.com/schemas/cooldown-summary-response.schema.json",
  "title": "Forge Fleet GET /v1/cooldown-summary 200 body (subset)",
  "type": "object",

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fleet.forgesdlc.com/schemas/health-response.schema.json",
  "title": "Forge Fleet GET /v1/health 200 body (subset)",
  "type": "object",
  "additionalProperties": true,
  "required": ["ok", "service"],
  "properties": {
    "ok": { "const": true },
    "service": { "const": "forge-fleet" },
    "auth_enforced": { "type": "boolean" },
    "version": { "type": "object", "additionalProperties": true },
    "host": { "type": "object", "additionalProperties": true }
  }
}

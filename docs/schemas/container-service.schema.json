{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fleet.forgesdlc.com/schemas/container-service.schema.json",
  "title": "Forge Fleet managed service record",
  "description": "JSON file under etc/services/<id>.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "id", "type_id", "label", "compose_root", "compose_files"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9_-]{0,63}$" },
    "type_id": { "type": "string", "minLength": 1 },
    "label": { "type": "string" },
    "compose_root": { "type": "string", "minLength": 1 },
    "compose_files": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
